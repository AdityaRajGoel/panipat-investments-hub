# Copy to .env and fill in. NEVER commit .env — it is gitignored.
#
# Only VITE_* vars are read by the frontend build. They are embedded in the
# client bundle and are therefore PUBLIC by design — the anon key is safe to
# expose because every table is protected by Row Level Security.

# Supabase — Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# ---------------------------------------------------------------------------
# Server-side secrets — do NOT put these here or in .env.
# They are read via Deno.env inside Supabase Edge Functions only, and must be
# set as function secrets:
#
#   supabase secrets set GEMINI_API_KEY=...           # ai-stock-analysis
#   supabase secrets set GROQ_API_KEY=...             # ai-stock-analysis
#   supabase secrets set SYNC_SECRET=...              # sync-market-feed, sync-bhavcopy
#   supabase secrets set TELEGRAM_BOT_TOKEN=...       # telegram-webhook
#   supabase secrets set TELEGRAM_WEBHOOK_SECRET=...  # telegram-webhook
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
# Edge Function runtime — never set or commit them yourself.
#
# GitHub Actions secrets (Settings > Secrets and variables > Actions):
#   SUPABASE_ANON_KEY, MARKET_SYNC_SECRET
# ---------------------------------------------------------------------------
